<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:padding="24dp">

    <TextView android:id="@+id/tvDetails" android:layout_width="match_parent" android:layout_height="wrap_content" android:textSize="18sp" android:layout_marginBottom="24dp"/>

    <Button android:id="@+id/btnEdit" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Sửa Thông Tin"/>
    <Button android:id="@+id/btnDelete" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Xóa Nhân Viên" android:backgroundTint="@android:color/holo_red_dark"/>
</LinearLayout>